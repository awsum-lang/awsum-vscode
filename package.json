{
  "name": "awsum-vscode",
  "displayName": "Awsum",
  "description": "Awsum language support for Visual Studio Code",
  "publisher": "awsum-lang",
  "version": "0.0.4",
  "engines": {
    "node": ">=24.14",
    "vscode": "^1.118.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/awsum-lang/awsum-vscode.git"
  },
  "icon": "icons/extension-icon.png",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "awsum",
        "aliases": [
          "Awsum"
        ],
        "extensions": [
          ".aww"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/awsum-light.svg",
          "dark": "./icons/awsum.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "awsum",
        "scopeName": "source.awsum",
        "path": "./syntaxes/awsum.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Awsum",
      "properties": {
        "awsum.path": {
          "type": "string",
          "default": "awsum",
          "description": "Path to the `awsum` binary (if not in PATH). For example: /usr/local/bin/awsum"
        }
      }
    },
    "configurationDefaults": {
      "[awsum]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "awsum-lang.awsum-vscode"
      }
    }
  },
  "files": [
    "dist",
    "syntaxes",
    "language-configuration.json",
    "icons",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p .",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node22 --minify",
    "package": "npm run bundle && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/vscode": "^1.118.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
